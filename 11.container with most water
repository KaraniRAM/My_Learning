  class Solution(object):
    def maxArea(self, height):
        i=0;j=len(height)-1;con=0
        while i < j:
            if height[i] < height[j]:
                g=(j-i)*height[i]
                if g>con:
                    con=g     
            else:
                g=(j-i)*height[j]
                if g>con:
                    con=g
            if height[i]<height[j]:
                i+=1
            else:
                j-=1
        return con

