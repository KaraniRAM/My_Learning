class Solution(object):
    def reverseVowels(self, s):
        s=list(s)
        v='aeiouAEIOU'
        i=0
        j=len(s)-1
        while i<j:
            if s[i] in v and (s[j] in v):
                s[i],s[j]=s[j],s[i]
                i+=1
                j-=1
            if  s[i] not  in v:
                i+=1
            if s[j] not in v:
                j-=1
        return "".join(s)



