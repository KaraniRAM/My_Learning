class Solution(object):
    def intersect(self, nums1, nums2):
        g = sorted(nums1)
        k = sorted(nums2)
        i = 0
        j = 0
        result = []
        while i < len(g) and j < len(k):
            if g[i] == k[j]:
                result.append(g[i])
                i += 1
                j += 1
            elif g[i] < k[j]:
                i += 1
            else:
                j += 1

        return result
